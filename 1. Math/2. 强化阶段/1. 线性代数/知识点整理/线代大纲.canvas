			"y":-7690,
			"width":350,
			"height":90,
			"color":"1"
		},
		{
			"id":"57ff9cbe7971d7b8",
			"type":"text",
			"text":"9. 行列式与高数--优先关注带 x 的！",
			"styleAttributes":{"textAlign":"center"},
			"x":6930,
			"y":-7420,
			"width":350,
			"height":120
		},
		{
			"id":"e2dca7cfedf75a93",
			"type":"text",
			"text":"三对角型行列式\n1. 按第一行展开；\n2. 构造等差数列；\n3. 同除以一个数，构造等比数列；\n4. ==别忘了首项单独考虑！==",
			"styleAttributes":{"textAlign":"center"},
			"x":7540,
			"y":-7520,
			"width":380,
			"height":200
		},
		{
			"id":"ef426521297019a4",
			"type":"text",
			"text":"7. 行列式与矩阵相似",
			"styleAttributes":{"textAlign":"center"},
			"x":6270,
			"y":-6410,
			"width":260,
			"height":60
		},
		{
			"id":"03d4d3883b9ecec1",
			"type":"text",
			"text":"4. 行列式与向量",
			"styleAttributes":{"textAlign":"center"},
			"x":6340,
			"y":-6890,
			"width":260,
			"height":60
		},
		{
			"id":"47acc29b295e3151",
			"type":"text",
			"text":"5. 行列式与方程组",
			"styleAttributes":{"textAlign":"center"},
			"x":6310,
			"y":-6730,
			"width":260,
			"height":60
		},
		{
			"id":"fc2c4f5102341b36",
			"type":"text",
			"text":"1. 行列式与矩阵乘法",
			"styleAttributes":{"textAlign":"center"},
			"x":6310,
			"y":-7420,
			"width":260,
			"height":60
		},
		{
			"id":"33b11ab4446876d1",
			"type":"text",
			"text":"3. 行列式与几类常见矩阵",
			"styleAttributes":{"textAlign":"center"},
			"x":6310,
			"y":-7110,
			"width":320,
			"height":80
		},
		{
			"id":"7d0e15566431b28c",
			"type":"text",
			"text":"2. 行列式与矩阵方阵",
			"styleAttributes":{"textAlign":"center"},
			"x":6400,
			"y":-7250,
			"width":260,
			"height":60
		},
		{
			"id":"0f9fe1cbc93e5f61",
			"type":"text",
			"text":"### 行列式\n**求行列式最朴素的计算方法就是化 0。**\n即所谓的**\"化 0 降阶法\"**",
			"styleAttributes":{
				"textAlign":null
			},
			"x":4980,
			"y":-8000,
			"width":400,
			"height":180,
			"color":"5"
		},
		{
			"id":"7a0410daabb6dc01",
			"type":"text",
			"text":"例 21--反对称矩阵的结论\n1. 主对角元素=0；\n2. 当矩阵维数为奇数，行列式=0；",
			"styleAttributes":{"textAlign":"center"},
			"x":4960,
			"y":-8400,
			"width":440,
			"height":160
		},
		{
			"id":"6c14b6eb57f5c776",
			"type":"text",
			"text":"例 20-- $a_{ij}$ 与 $A_{ij}$ P11",
			"styleAttributes":{"textAlign":"center"},
			"x":4980,
			"y":-8540,
			"width":260,
			"height":60
		},
		{
			"id":"f29140f6591dec3e",
			"type":"text",
			"text":"例 23--观察，真题不会随意给信息！",
			"styleAttributes":{"textAlign":"center"},
			"x":5340,
			"y":-8830,
			"width":290,
			"height":100
		},
		{
			"id":"11e40041f742a7f6",
			"type":"text",
			"text":"5. 行列同数行列式\n法一：加边法；\n法二：用 4 行和相等",
			"styleAttributes":{"textAlign":"center"},
			"x":6850,
			"y":-8250,
			"width":320,
			"height":100
		},
		{
			"id":"8bf81df99a3de667",
			"type":"text",
			"text":"4. 行和相等行列式\n法一：全部加到第一行提公因式；\n法二：特征值法：拆成两个矩阵求特征值，其中一个比是对角阵。再利用特征值之积=行列式；",
			"styleAttributes":{"textAlign":"center"},
			"x":6645,
			"y":-8560,
			"width":600,
			"height":200
		},
		{
			"id":"b88a86d3aa835778",
			"type":"text",
			"text":"X 型行列式\n1. 最后一行逐行对换到第二行；\n2. 最后一列逐行对换到第一列；\n3. $Laplace$ 展开；",
			"styleAttributes":{"textAlign":"center"},
			"x":7540,
			"y":-7980,
			"width":380,
			"height":160
		},
		{
			"id":"94ab514569fe1338",
			"type":"text",
			"text":"6. 范德蒙行列式--公式识别",
			"styleAttributes":{"textAlign":"center"},
			"x":6870,
			"y":-8070,
			"width":310,
			"height":80
		},
		{
			"id":"74bc823d0a38abbc",
			"type":"text",
			"text":"7. 拉普拉斯行列式--公式识别",
			"styleAttributes":{"textAlign":"center"},
			"x":6870,
			"y":-7920,
			"width":300,
			"height":80
		},
		{
			"id":"93c4dfb98a62c2d5",
			"type":"text",
			"text":"例 25-- $A$ 各行元素和=a，转换为特征向量与特征值",
			"styleAttributes":{"textAlign":"center"},
			"x":5340,
			"y":-8670,
			"width":320,
			"height":100
		},
		{
			"id":"6a90e6e789ce2e50",
			"type":"text",
			"text":"例 10--加边法",
			"styleAttributes":{"textAlign":"center"},
			"x":4960,
			"y":-8830,
			"width":260,
			"height":60
		},
		{
			"id":"eceebec2b7d71b8e",
			"type":"text",
			"text":"例 8--特征值法",
			"styleAttributes":{"textAlign":"center"},
			"x":4960,
			"y":-8920,
			"width":260,
			"height":60
		},
		{
			"id":"6e8e92bf3cdfd758",
			"type":"text",
			"text":"***行列式按行按列展开后，容易忘记成展开系数!!!***",
			"styleAttributes":{"textAlign":"center"},
			"x":4980,
			"y":-9180,
			"width":280,
			"height":120
		},
		{
			"id":"b59576a48357acf6",
			"type":"text",
			"text":"6. 行列式与特征值，特征向量",
			"styleAttributes":{"textAlign":"center"},
			"x":6260,
			"y":-6560,
			"width":310,
			"height":100
		},
		{
			"id":"592e7a341e019436",
			"type":"text",
			"text":"例 26--模式识别：给出可逆矩阵和矩阵恒等式, 转化为矩阵相似处理",
			"styleAttributes":{"textAlign":"center"},
			"x":5300,
			"y":-8550,
			"width":360,
			"height":100
		},
		{
			"id":"6dc08110fa8d2464",
			"type":"text",
			"text":"**10. 抽象型行列式的计算(重难点!)**",
			"styleAttributes":{"textAlign":"center"},
			"x":5453,
			"y":-7680,
			"width":415,
			"height":160,
			"color":"1"
		},
		{
			"id":"cefbf9850a10239d",
			"type":"text",
			"text":"3. 么型行列式\n法一：沿开口方向展开\n\t(处理**递推型**行列式, 可利用此法找到递推关系);\n法二：消掉异爪，逐行相加;",
			"styleAttributes":{"textAlign":"center"},
			"x":6685,
			"y":-8840,
			"width":520,
			"height":200
		},
		{
			"id":"c04c2db7cad00831",
			"type":"text",
			"text":"2. 矩阵相似对角化的一般求解步骤（多练，这是后续问题的核心！）",
			"styleAttributes":{"textAlign":"center"},
			"x":5132,
			"y":1440,
			"width":400,
			"height":100,
			"color":"1"
		},
		{
			"id":"d05dde6d8a1459f8",
			"type":"text",
			"text":"1. 充要、充分、必要条件--做到熟练自如",
			"styleAttributes":{"textAlign":"center"},
			"x":5142,
			"y":1320,
			"width":390,
			"height":110,
			"color":"4"
		},
		{
			"id":"c1b9007e3518fb3d",
			"type":"text",
			"text":"1. 一点一线/二线行列式--按所在行列展开",
			"styleAttributes":{"textAlign":"center"},
			"x":6750,
			"y":-9260,
			"width":420,
			"height":120
		},
		{
			"id":"9110c6d5e0ed5863",
			"type":"text",
			"text":"2. 爪型行列式--斜抓消平抓",
			"styleAttributes":{"textAlign":"center"},
			"x":6795,
			"y":-9060,
			"width":330,
			"height":120
		},
		{
			"id":"54e8b7d2a9be28e6",
			"type":"text",
			"text":"#### 实对称矩阵正交对角化的一般步骤--注意避开\"史\"!\n\n##### 类型二、实对称矩阵相似计算(求正交矩阵 $Q$)\n==例 8==",
			"styleAttributes":{"textAlign":"center"},
			"x":5702,
			"y":3221,
			"width":690,
			"height":220
		},
		{
			"id":"3566f42e3408cd40",
			"type":"text",
			"text":"#### 类型一、利用实对称矩阵的性质解决问题\n例 3--值得积累：注意⚠️：特征向量的长度可以任意变化！\n例 4--注意⚠️：实对称矩阵==天生可对角化==，因此两实对称矩阵是否相似，看其特征值是否相等即可！\n==例 6==--好好体会！真的好题",
			"styleAttributes":{"textAlign":"center"},
			"x":5747,
			"y":2931,
			"width":600,
			"height":220
		},
		{
			"id":"3cf73194d2fbce7d",
			"type":"text",
			"text":"#### 类型二、判断具体矩阵/==抽象矩阵(重点照顾)==是否相似\n杀手锏高频应用场地\n例 7--结论",
			"styleAttributes":{"textAlign":"center"},
			"x":6957,
			"y":2341,
			"width":500,
			"height":219,
			"color":"1"
		},
		{
			"id":"7ceb8c0bb2376369",
			"type":"text",
			"text":"#### 类型三、证明矩阵相似--考频低，但出现过！",
			"styleAttributes":{"textAlign":"center"},
			"x":6957,
			"y":2601,
			"width":480,
			"height":140
		},
		{
			"id":"f8f2bf3154573aa1",
			"type":"text",
			"text":"#### 类型四、具体型/抽象型矩阵相似计算(求可逆矩阵 $P$)--流程图捋顺很重要!",
			"styleAttributes":{"textAlign":"center"},
			"x":6817,
			"y":2851,
			"width":580,
			"height":80
		},
		{
			"id":"2e5e454563fc0a28",
			"type":"text",
			"text":"两个不熟的充分条件：\n1. 若 $n$ 阶矩阵 $A$ 满足 $A^2 = A$，则矩阵 $A$ 必相似与对角阵；\n2. 若 $n$ 阶矩阵 $A$ 满足 $A^2 = E$，则矩阵 $A$ 必相似与对角阵；",
			"styleAttributes":{"textAlign":"center"},
			"x":5132,
			"y":1580,
			"width":560,
			"height":200
		},
		{
			"id":"19978ab0bfee9021",
			"type":"text",
			"text":"#### ==4. 关于 $A$ 及 $A$ 有关的常用矩阵的特征值和特征向量==",
			"styleAttributes":{"textAlign":"center"},
			"x":6730,
			"y":281,
			"width":600,
			"height":180
		},
		{
			"id":"3d2e1320c44088af",
			"type":"text",
			"text":"#### 1. 相关性质\n==特征值与相似对角化的关系==",
			"styleAttributes":{"textAlign":"center"},
			"x":6480,
			"y":647,
			"width":360,
			"height":120
		},
		{
			"id":"22a15de4ef4ee167",
			"type":"text",
			"text":"#### 类型一 ：利用相似对角化的必要条件及性质解决问题（与特征值和特征向量结合）\n例 2\n例 4 结论",
			"styleAttributes":{"textAlign":"center"},
			"x":7070,
			"y":960,
			"width":480,
			"height":282
		},
		{"id":"0f144c597a0b5028","type":"file","file":"1. Math/2. 强化阶段/1. 线性代数/知识点整理/3. 矩阵相似/attachment/2.png","x":6440,"y":787,"width":604,"height":89},
		{
			"id":"2045cd46da00ec77",
			"type":"text",
			"text":"#### 3. 特征值与特征向量的相关性质",
			"styleAttributes":{"textAlign":"center"},
			"x":6800,
			"y":111,
			"width":360,
			"height":120
		},
		{
			"id":"2a4322f0efc57354",
			"type":"text",
			"text":"#### 2. 几何重数与代数重数(概念不熟)\n几何重数≤代数重数",
			"styleAttributes":{"textAlign":"center"},
			"x":6780,
			"y":-129,
			"width":400,
			"height":160
		},
		{
			"id":"6d91c935cd2c77cf",
			"type":"text",
			"text":"#### 类型二、判断/证明矩阵是否可相似对角化 ==(这里的例题都很好！值得多刷)==\n还是用 P76 的条件\n相似：充要条件，充分条件；\n不相似：几何重数＜代数重数；",
			"styleAttributes":{"textAlign":"center"},
			"x":7030,
			"y":1440,
			"width":480,
			"height":261
		},
		{
			"id":"e84b202cbda47b24",
			"type":"text",
			"text":"#### 1. 求解方法",
			"styleAttributes":{"textAlign":"center"},
			"x":6900,
			"y":-269,
			"width":260,
			"height":60
		},
		{
			"id":"1da5852223949af2",
			"type":"text",
			"text":"### 一、特征值与特征向量",
			"styleAttributes":{"textAlign":"center"},
			"x":6080,
			"y":71,
			"width":320,
			"height":80
		},
		{
			"id":"89024b886b11b64a",
			"type":"text",
			"text":"不同特征值的特征向量天然无关-->==拓展: 实对称矩阵的不同特征值的特征向量天然正交==",
			"styleAttributes":{"textAlign":"center"},
			"x":8310,
			"y":-109,
			"width":320,
			"height":140
		},
		{
			"id":"52d44775fb57324c",
			"type":"text",
			"text":"相同特征值的特征向量的非 $0$ 线性组合，仍是该特征值的特征向量；",
			"styleAttributes":{"textAlign":"center"},
			"x":8280,
			"y":-299,
			"width":350,
			"height":119
		},
		{
			"id":"795334aeecf1b007",
			"type":"text",
			"text":"某个特征值对应一个特征向量，那么这个向量乘 $k$ 倍依然是这个特征值的特征向量；",
			"styleAttributes":{"textAlign":"center"},
			"x":8300,
			"y":141,
			"width":340,
			"height":140
		},
		{
			"id":"52db72fb86c85095",
			"type":"text",
			"text":"==**已知 $A^{-1}$ 和 $kA+bE$ 的特征值(特征向量)可倒推 $A$ 的特征值(特征向量)；**==\n***其他情况都不行！***",
			"styleAttributes":{"textAlign":"center"},
			"x":9070,
			"y":501,
			"width":370,
			"height":240
		},
		{
			"id":"09fc962a78649fae",
			"type":"text",
			"text":"例题 5",
			"styleAttributes":{"textAlign":"center"},
			"x":9125,
			"y":781,
			"width":260,
			"height":60
		},
