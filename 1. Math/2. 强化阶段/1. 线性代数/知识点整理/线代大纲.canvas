		{
			"id":"632ecc5ca0b305ab",
			"type":"text",
			"text":"### 四、套皮二次型",
			"styleAttributes":{"textAlign":"center"},
			"x":6163,
			"y":7560,
			"width":260,
			"height":60
		},
		{
			"id":"13bb3f9597086cf7",
			"type":"text",
			"text":"### 五、平方和形式的二次型应用--一定要回看，会熟练使用性质!(送分题!)",
			"styleAttributes":{"textAlign":"center"},
			"x":6640,
			"y":7800,
			"width":420,
			"height":140
		},
		{
			"id":"2f81a5636e2ce0b0",
			"type":"text",
