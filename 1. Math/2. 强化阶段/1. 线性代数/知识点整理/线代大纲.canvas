		{"id":"b17077feab95f14d","type":"file","file":"1. Math/2. 强化阶段/1. 线性代数/知识点整理/1. 行列式与矩阵/attachment/1-8--结合32页笔记看-6.png","x":6760,"y":-3060,"width":400,"height":211},
