			"height":390
		},
		{
			"id":"afc508ec4518c326",
			"type":"text",
			"text":"## 矩阵相似",
			"styleAttributes":{"textAlign":"center"},
			"x":1190,
			"y":2186,
			"width":580,
			"height":311
		},
		{
			"id":"1ea21c413d65178c",
			"type":"text",
			"text":"## 二次型\n1. 对象，基础工具；\n2. ==重要！基础方法:==\n\t1. 正交变换法\n\t2. 配方法\n3. 综合题(类型多！)",
			"styleAttributes":{"textAlign":"center"},
			"x":1480,
			"y":6785,
			"width":340,
			"height":240
		},
		{
			"id":"7865160425274bfb",
			"type":"text",
			"text":"### 八、二次型最值问题\n解题模板固定，小题大题都可能考！",
			"styleAttributes":{"textAlign":"center"},
			"x":7800,
			"y":7600,
			"width":690,
			"height":160
		},
		{
			"id":"9d79e16573e810ba",
			"type":"text",
			"text":"### 十、矩阵等价、相似、合同--概念辨析，选填，==热门考点！==",
			"styleAttributes":{"textAlign":"center"},
			"x":7728,
			"y":8500,
			"width":340,
			"height":149
		},
		{
			"id":"e47c0cfa955e31b9",
			"type":"text",
			"text":"小题：\n1. 正惯性指数 p = n\n2. A 的特征值均大于 0\n3. 所有顺序主子式大于零",
			"styleAttributes":{
				"textAlign":null
			},
			"x":7668,
			"y":8200,
			"width":270,
			"height":270
		},
		{
			"id":"07e1e82e395202a4",
			"type":"text",
			"text":"### 七、二次型化成另一个二次型(求变换手段)\n$$\nA \\Longrightarrow \\Lambda \\Longleftarrow B\n$$\n$$\nA \\Longrightarrow \\Lambda \\Longrightarrow B\n$$",
			"styleAttributes":{"textAlign":"center"},
			"x":6640,
			"y":8575,
			"width":580,
			"height":186
		},
		{
			"id":"eb1d7e6742642315",
			"type":"text",
			"text":"例 4 很套路！类似于同时对角化问题！重视！",
			"styleAttributes":{"textAlign":"center"},
			"x":6640,
			"y":8760,
			"width":290,
			"height":120,
			"color":"3"
		},
		{
			"id":"f6dfd13fa861d37c",
			"type":"text",
			"text":"总结--平方和形式二次型的性质：\n1\n2\n3",
			"styleAttributes":{"textAlign":"center"},
			"x":6640,
			"y":7940,
			"width":380,
			"height":130,
			"color":"4"
		},
		{
			"id":"2fdedd9ac8979439",
			"type":"text",
			"text":"### 六、二次型=0 的求解",
			"styleAttributes":{"textAlign":"center"},
			"x":6770,
			"y":8160,
			"width":340,
			"height":100
		},
		{
			"id":"7f8ddce921e148b0",
			"type":"text",
			"text":"大题：\n1. A 与 E 合同\n2. 存在可逆矩阵 D，使得 $A=D^{T}D$",
			"styleAttributes":{"textAlign":"center","shape":"predefined-process"},
			"x":7938,
			"y":8200,
			"width":260,
			"height":220,
			"color":"3"
		},
		{
			"id":"7296ef4122b3466d",
			"type":"text",
			"text":"#### 合同\n1. 定义\n2. ==惯性指数(要会灵活运用!)==\n3. 传递性",
			"styleAttributes":{"textAlign":"center"},
			"x":8780,
			"y":8800,
			"width":460,
			"height":180
		},
		{
			"id":"3d81fd77b48a0046",
			"type":"text",
			"text":"#### 等价-- $r(A)=r(B)$",
			"styleAttributes":{"textAlign":"center"},
			"x":8880,
			"y":8470,
			"width":260,
			"height":60
		},
		{
			"id":"ebc6fa764f8f64ee",
			"type":"text",
			"text":"一定要利用充要条件！特别是大题！不然找不到思路的！",
			"styleAttributes":{"textAlign":"center"},
			"x":7668,
			"y":8120,
			"width":530,
			"height":80
		},
		{
			"id":"a0abfe7463abe9fd",
			"type":"text",
			"text":"本质考的是实对称矩阵相似对角化",
			"styleAttributes":{"textAlign":"center","shape":"document"},
			"x":6123,
			"y":7620,
			"width":340,
			"height":80,
			"color":"4"
		},
		{
			"id":"2868157bc388be27",
			"type":"text",
			"text":"2 点理论：\n1. 正交变换不改变向量长度；\n2. 通过特征值大小找不等式；",
			"styleAttributes":{"textAlign":"center","shape":"document"},
			"x":7800,
			"y":7760,
			"width":360,
			"height":220,
			"color":"4"
		},
		{
			"id":"9149518d3b9d4476",
			"type":"text",
			"text":"### 九、正定二次型--大题爱考! 重视!",
			"styleAttributes":{"textAlign":"center"},
			"x":7668,
			"y":8020,
			"width":530,
			"height":100,
			"color":"1"
		},
		{
			"id":"e11bd8be564740ea",
			"type":"text",
			"text":"理解：\n$x^{T}Ax$ 是一个数！\n$\\lambda x^{T}x$ 也是一个数！\n\n==重点是要把 $A$ 利用正交变换换成 $\\Lambda$ 这样才能看出来！==",
			"styleAttributes":{"textAlign":"center"},
			"x":8160,
			"y":7760,
			"width":330,
			"height":220,
			"color":"2"
		},
		{
			"id":"12eddf5f5371468e",
			"type":"text",
			"text":"#### 相似\n先从必要条件入手--如不满足，必然不相似==(小题)==: \n行列式; tr; r;  λ;\n再借助定义或传递性==(大题)==；",
			"styleAttributes":{"textAlign":"center"},
			"x":8240,
			"y":8415,
			"width":460,
			"height":220
		},
		{
			"id":"54768bb887e92313",
			"type":"text",
			"text":"### 一、二次型及其表示\n==定义这里是送分题，谨慎！千万不要犯低级错误!!!==",
			"styleAttributes":{"textAlign":"center"},
			"x":6523,
			"y":6100,
			"width":500,
			"height":200
		},
		{
			"id":"a19ca6ae10203ca6",
			"type":"text",
			"text":"平方和型二次型 ⇄ 内积型的快速写法--通过矩阵乘法\n例 4 注意额外的技巧! (四秩相等+非满秩矩阵行列式=0)\n例 5 注意谱分解的感觉！",
			"styleAttributes":{"textAlign":"center"},
			"x":6523,
			"y":6300,
			"width":500,
			"height":200,
			"color":"1"
		},
		{"id":"d3c71568500ef06a","type":"file","file":"1. Math/2. 强化阶段/1. 线性代数/知识点整理/3. 矩阵相似/attachment/4--证明过程.jpg","x":5610,"y":4364,"width":580,"height":497},
		{
			"id":"328451f8005b9d02",
			"type":"text",
			"text":"思路很简单，利用正交变换或配方法得到平方和=0 的形式，再变换回原来的 $x=...$ 的形式(因为要求的是 $x$ 的解)",
			"styleAttributes":{"textAlign":"center","shape":"document"},
			"x":6730,
			"y":8260,
			"width":540,
			"height":155,
			"color":"4"
		},
